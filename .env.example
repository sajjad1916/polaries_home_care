# Polaris Home Care - Environment Variables
# Copy to .env and fill in values

# Server
PORT=3000
NODE_ENV=development
APP_SECRET=change-me-to-a-random-string

# Admin credentials (created on first run via seed)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=polaris2026

# AI Document Scanning (optional - manual entry works without this)
GEMINI_API_KEY=

# File Storage
# "local" stores in ./uploads, "r2" uses Cloudflare R2
STORAGE_MODE=local
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=

# Database
DB_PATH=./db/polaris.db
